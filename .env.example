# ─── Core ───────────────────────────────────────────────────────────────────
# Postgres connection string (local or cloud, e.g. Neon/Supabase)
DATABASE_URI=postgres://user:password@localhost:5432/viralpx
# Long random string used to sign/encrypt tokens
PAYLOAD_SECRET=change-me-to-a-long-random-string
# Public URL of the app (used for admin, links, SEO)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Cloudflare R2 (S3-compatible media storage) ────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=viralpx-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public CDN base URL for the bucket (e.g. https://cdn.viralpx.com)
R2_PUBLIC_URL=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=ViralPX <noreply@viralpx.com>

# ─── Seeding (leave UNSET in production) ────────────────────────────────────
# Set to "true" only while seeding a fresh DB to expose /api/seed + /api/bootstrap.
# Unset it before real launch — the routes return 404 when this is not "true".
# ENABLE_SEED_ROUTES=true
